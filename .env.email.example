# ============================================================================
# EMAIL SERVICE CONFIGURATION
# ============================================================================
# Configure your email service for contact forms and subscriber notifications

# Resend Email Service (https://resend.com)
# 1. Sign up at https://resend.com
# 2. Create an API key in your dashboard
# 3. Verify your sender domain (or use the default noreply domain)
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# Email sender configuration
VITE_RESEND_FROM_EMAIL=noreply@nenshasworld.com

# Admin email address (receives contact form submissions and subscriber notifications)
VITE_ADMIN_EMAIL=your-email@example.com

# API Base URL for email endpoint
# For local development: http://localhost:3000 (or your Vite dev server port)
# For production: https://your-domain.com
VITE_API_BASE_URL=http://localhost:3000

# ============================================================================
# OPTIONAL: Additional Email Configuration
# ============================================================================

# Newsletter sender name (displayed in email)
VITE_EMAIL_FROM_NAME="NENSHA JENNIFER"

# Support email (for user inquiries)
VITE_SUPPORT_EMAIL=support@nenshasworld.com

# ============================================================================
# DEVELOPMENT MODE
# ============================================================================
# Set to 'true' to log emails instead of sending (useful for testing)
VITE_EMAIL_DEV_MODE=false
